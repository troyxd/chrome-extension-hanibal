{
  "name": "Hanibal shoe labels",
  "version": "0.1.0",
  "description": "Create labels for shoes",
  "permissions": [
    "storage",
    "tabs",
    "printing"
  ],
  "host_permissions": [
    "https://*.hanibal.cz/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.hanibal.cz/*"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/add.png",
        "assets/delete.png",
        "assets/save.png"
      ],
      "matches": [
        "https://*.hanibal.cz/*"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/logo.png",
      "24": "assets/logo.png",
      "32": "assets/logo.png"
    },
    "default_title": "Hanibal shoe labels",
    "default_popup": "popup.html"
  },
  "manifest_version": 3
}
